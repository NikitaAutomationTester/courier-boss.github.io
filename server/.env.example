# Скопируйте этот файл в .env и подставьте свой секрет:
#   cp .env.example .env
#   nano .env

# Секрет для входа (обязательно свой длинный случайный текст)
JWT_SECRET=замените_на_длинную_случайную_строку

# Порт (по умолчанию 3000)
# PORT=3000

# Только если сайт открывается по https:// (домен + сертификат)
# COOKIE_SECURE=1
